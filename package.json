{
	"name": "kevinap29.github.io",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"dev": "npm run paraglide:compile && vite dev --host",
		"dev:open": "vite dev --host --open",
		"build": "npm run paraglide:compile && npm run generate:sitemap && vite build",
		"preview": "vite preview --host --open",
		"build:preview": "npm run build && npm run preview",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"format:lint": "npm run format && npm run lint",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"generate:sitemap": "node scripts/generate-sitemap.js",
		"generate:pdf": "node scripts/generate-pdfs-from-sitemap.js"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.9.0",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/forms": "0.5.7",
		"@tailwindcss/typography": "0.5.13",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "20.14.2",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"autoprefixer": "10.4.19",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"dotenv": "^16.4.5",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.30.0",
		"formsnap": "^2.0.1",
		"paneforge": "^1.0.0-next.6",
		"postcss": "8.4.38",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tailwindcss-animate": "^1.0.7",
		"tslib": "^2.4.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^5.0.3",
		"vitest": "^1.0.0"
	},
	"type": "module",
	"dependencies": {
		"@inlang/paraglide-js": "^2.16.0",
		"@inlang/paraglide-sveltekit": "^0.16.1",
		"@types/marked": "^6.0.0",
		"fast-xml-parser": "^5.7.1",
		"gray-matter": "^4.0.3",
		"highlight.js": "11.9.0",
		"marked": "^18.0.2",
		"mode-watcher": "^1.1.0",
		"pdf-lib": "^1.17.1",
		"puppeteer": "^24.14.0",
		"zod": "^3.23.8"
	}
}
